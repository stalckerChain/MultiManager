{
  "name": "multimanager",
  "version": "0.4.1",
  "description": "MVP кроссплатформенного антидетект-браузера с API для ИИ",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:api": "node tests/integration/api-real.test.js",
    "test:all": "vitest run --reporter=verbose && node tests/integration/api-real.test.js",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "axios": "^1.18.1",
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.0",
    "koffi": "^3.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "socks": "^2.8.9",
    "tree-kill": "^1.2.2",
    "uuid": "^11.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "eslint": "^9.23.0",
    "nock": "^14.0.15",
    "node-addon-api": "^8.9.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "pkg": {
    "assets": [
      "node_modules/pino-pretty/**/*",
      "node_modules/pino/file/**/*",
      "node_modules/pino/lib/worker.js"
    ],
    "scripts": [
      "node_modules/pino-pretty/**/*.js",
      "node_modules/pino/file/**/*.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
